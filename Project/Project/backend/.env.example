# Copy this file to .env and adjust for your environment.
DB_URL=jdbc:mysql://localhost:3306/certifypro?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=root

# JWT access token (24h in ms) and refresh token (7d in ms)
JWT_SECRET=ChangeThisToAStrongRandomSecretKeyForCertifyProJWT2026!!
JWT_EXPIRY=86400000
REFRESH_SECRET=ChangeThisToAnotherStrongRandomRefreshSecretForCertifyPro2026!!
REFRESH_EXPIRY=604800000

PORT=8081
